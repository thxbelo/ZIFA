# ZIFA Admin Portal - Environment Configuration

# Backend Port
PORT=3001

# JWT Secret Key
# Required in production. Use a unique random value of at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret

# Database Provider (sqlite or neon)
DB_TYPE=neon

# Neon Configuration
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Comma-separated origins allowed to call the API and websocket server.
# Example: https://your-site.netlify.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional upload/body hardening
MAX_UPLOAD_MB=5
JSON_BODY_LIMIT=1mb

# Local development only. Never enable default admin seeding in production.
SEED_DEFAULT_ADMIN=false

# Frontend API base (optional)
# - Local dev default: http://localhost:3001
# - Netlify default: same-origin (leave blank)
# VITE_API_BASE_URL=
